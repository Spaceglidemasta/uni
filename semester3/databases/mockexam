create table `lieferant` (

    lieferant_id    int primary key auto_increment,
    lieferant_name  varchar(60),
    addresse        varchar(100),
    tel_num         varchar(32),
    email           varchar(50)

);

create table `artikelgruppe` (

    group_id        int primary key auto_increment,
    group_name      varchar(60),
    needs_cooling   boolean,
    bio             boolean,
    vegan           boolean

);

create table `artikel` (

    id INT AUTO_INCREMENT PRIMARY KEY,
    art_name varchar(60) NOT NULL,
    art_price float,
    group_id int not null,
    deliv_id int not null,

    constraint fk_artikel2artikelgruppe
        foreign key (group_id) references artikelgruppe(group_id),

    constraint fk_artikel2lieferant
        foreign key (deliv_id) references lieferant(lieferant_id)

);

lock table artikel write;
lock table artikelgruppe write;
lock table lieferant write;

